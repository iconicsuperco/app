  "version": "0.1.0",
  "type": "module",
  "description": "A premium personal music streaming web app",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
